# Copy this file to .env for local development
# On Railway, set these as environment variables in the dashboard

SECRET_KEY=your_random_secret_key_here
JWT_SECRET_KEY=another_random_secret_key_here

# Local: postgresql://postgres:yourpassword@localhost/edu_track
# Railway: provided automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql://postgres:yourpassword@localhost/edu_track

# Path to the trained YOLOv8 model weights
# Local: leave empty to use default (backend/model.pt)
# Railway: /app/backend/model.pt or wherever Railway places the repo
YOLO_MODEL_PATH=
